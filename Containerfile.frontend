FROM node:22-alpine AS build

WORKDIR /app

COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

COPY frontend/ .
RUN npm run build

FROM node:22-alpine

RUN npm install -g serve@14

WORKDIR /app
COPY --from=build /app/dist ./dist

RUN chmod -R g+rwX /app

EXPOSE 3000

CMD ["serve", "-s", "dist", "-l", "3000"]
