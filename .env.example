# ============================================================
# StarGate Platform — Environment Variables
# ============================================================
# Copy to .env and fill in values. NEVER commit .env files.
# All secrets must be env vars — never hardcode in source.
# ============================================================

# --- Database ---
# In-cluster: use the k8s service name. Locally: use localhost.
# NOTE: Do NOT use $(SHELL_VAR) syntax — Python reads env vars literally.
# For k8s, inject the password via Secret envFrom or a deploy script.
STARGATE_DATABASE_URL=postgresql://stargate:PASSWORD@localhost:5432/stargate

# --- LLM / MAAS ---
STARGATE_LITELLM_API_KEY=           # LiteLLM virtual key from MAAS
STARGATE_LITELLM_URL=               # LiteLLM endpoint URL
STARGATE_LLM_MODEL=granite-3-2-8b-instruct

# --- Admin Auth ---
STARGATE_ADMIN_API_KEY=             # API key for admin endpoints (generated at deploy)

# --- External Data Sources ---
STARGATE_LABAGATOR_URL=             # Labagator REST API base URL
STARGATE_DEMOLITION_URL=            # Demolition REST API base URL
STARGATE_SANDBOX_API_METRICS_URL=   # Sandbox API Prometheus metrics endpoint
STARGATE_DASHBOARD_URL=             # Public dashboard URL (for Slack notifications)

# --- OAuth ---
STARGATE_OAUTH_COOKIE_SECRET=       # Random 32-char hex (openssl rand -hex 16)

# --- AgnosticV ---
STARGATE_AGNOSTICV_TOKEN=           # GitHub PAT for AgnosticV repo clone
STARGATE_AGNOSTICV_DIR=             # Local path to AgnosticV checkout

# --- Scanner ---
STARGATE_CLUSTERS=                  # Comma-separated cluster names or JSON dict
STARGATE_SSL_VERIFY=true            # Set to "false" for internal self-signed certs

# --- Execution ---
STARGATE_EXECUTION_TARGET=mock      # mock | test | production
STARGATE_REMEDIATION_NS=launchpad-,stargate,deepfield,intel-rh-,user-demo-,partner-ai-  # Namespace prefixes allowed for remediation
STARGATE_DRY_RUN=true               # Set to "false" to enable real execution
STARGATE_TEST_NAMESPACE=stargate-test
STARGATE_CONFIDENCE_THRESHOLD=0.8

# --- Event Filtering ---
STARGATE_EVENT_PREFIX=              # e.g., "summit-2026" — empty = all events
STARGATE_EVENT_DATE=                # ISO date for event countdown
STARGATE_EVENT_NAME=Platform Operations

# --- Notifications ---
STARGATE_SLACK_WEBHOOK_URL=         # Slack incoming webhook for alerts
STARGATE_WEBHOOK_URL=               # Generic webhook URL

# --- Integrations ---
STARGATE_LAUNCHPAD_URL=             # Launchpad API URL for session data
STARGATE_LAUNCHPAD_API_KEY=         # Launchpad API key
STARGATE_DEEPFIELD_URL=             # DeepField API URL
STARGATE_SANDBOX_API_URL=           # Sandbox API base URL (for RHDP actions)
STARGATE_ZEROTOUCH_URL=             # ZeroTouch API URL
STARGATE_EXECUTOR_KUBECONFIG=       # Kubeconfig path for remediation execution

# --- AgnosticV ---
STARGATE_AGNOSTICV_REPO=            # AgnosticV git repo URL

# --- LLM Advanced ---
STARGATE_AUTO_LLM=                  # Enable auto-LLM classification (true/false)
STARGATE_LLM_COST_PROMPT=0.003     # Cost per 1K prompt tokens
STARGATE_LLM_COST_COMPLETION=0.006 # Cost per 1K completion tokens
STARGATE_EVIDENCE_SOURCE=real       # real | synthetic

# --- Scanner Advanced ---
STARGATE_CLUSTERS_FILE=             # Path to YAML clusters config file
STARGATE_AAP_EVENT=                 # AAP event prefix filter

# --- CORS ---
STARGATE_CORS_ORIGINS=http://localhost:3000,http://localhost:8090
